# 설정 템플릿. 복사해서 .env 로 쓰고 값을 채운다 (.env 는 git 커밋 금지).
# cp .env.example .env   (Windows PowerShell: Copy-Item .env.example .env)

# --- KIS(한국투자증권) OpenAPI · 실시간 시세 ---
# 개발자센터(https://apiportal.koreainvestment.com)에서 발급한 앱키/시크릿.
# 비우면 무료 소스(FinanceDataReader, ~15분 지연)로 자동 폴백한다.
KIS_APP_KEY=
KIS_APP_SECRET=
# 실전계좌: https://openapi.koreainvestment.com:9443  /  모의투자: https://openapivts.koreainvestment.com:29443
KIS_DOMAIN=https://openapi.koreainvestment.com:9443

# --- 감시 대상 (콤마 구분) ---
KR_SYMBOLS=005930,000660
US_SYMBOLS=NQ=F

# --- 임계값: 전일 종가 대비 %. 설정만 바꿔 확장 가능 (예: 3.0,-3.0,6.0,-6.0) ---
THRESHOLDS=3.0,-3.0

# --- 폴링 / 시장 시간 (KST) ---
POLL_INTERVAL_SECONDS=30
MARKET_OPEN=08:00
MARKET_CLOSE=20:00
BRIEFING_TIME=07:00

# --- 세션 경계 (KST): 프리장 08:00~09:00 / 본장 09:00~15:40 / 에프터장 15:40~20:00 ---
SESSION_PRE_OPEN=08:00
SESSION_REGULAR_OPEN=09:00
SESSION_REGULAR_CLOSE=15:40
SESSION_AFTER_CLOSE=20:00

# --- 접근 제어: 허용된 Telegram chat id (콤마 구분). 비우면 제한 없음(개발용) ---
ALLOWED_CHAT_IDS=

# --- Hermes 게이트웨이 (같은 VPS, localhost 내부 통신) ---
HERMES_BASE_URL=http://localhost:8080

# --- 국토부 아파트매매 실거래가 OpenAPI (핀테크 탭 부동산 거래량) ---
# data.go.kr '아파트 매매 실거래가 상세자료' 활용신청(무료) 후 받은 서비스키(디코딩값).
# 비우면 부동산 카드는 '키 필요' 안내만 표시.
MOLIT_API_KEY=

# --- 저장소 ---
DB_PATH=data/stock.db
